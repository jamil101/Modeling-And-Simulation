// ----------- GET CURRENT TIME (using millis for uptime) -----------
String getTimeString()
{
  unsigned long seconds = millis() / 1000;
  int hours = (seconds / 3600) % 24;
  int minutes = (seconds / 60) % 60;
  int secs = seconds % 60;

  char timeStr[9];
  sprintf(timeStr, "%02d:%02d:%02d", hours, minutes, secs);
  return String(timeStr);
}

// ----------- CHECK RAIN STATUS (display only) -----------
void updateRainStatus()
{
  // Check if it's raining based on rain sensor reading (for display only)
  if (rainLevel > RAIN_THRESHOLD)
  {
    if (!isRaining)
    {
      isRaining = true;
      Serial.println("☔ RAIN DETECTED! (Display only)");
    }
  }
  else
  {
    if (isRaining)
    {
      isRaining = false;
      Serial.println("☀️ Rain stopped. (Display only)");
    }
  }
}

// ----------- SETUP -----------
void setup()
{
  Serial.begin(115200);
  delay(1000);

  Serial.println("Smart Farming System Starting...");

  // Initialize LCD
  lcd.init();
  lcd.backlight();
  lcd.clear();

  // Show project name first
  lcd.setCursor(0, 0);
  lcd.print(PROJECT_NAME);
  lcd.print(" ");
  lcd.print(VERSION);
  lcd.setCursor(0, 1);
  lcd.print("Initializing...");
  delay(2000);

  // Initialize components
  dht.begin();

  pinMode(PUMP_RELAY, OUTPUT);
  pinMode(FAN1_RELAY, OUTPUT);
  pinMode(FAN2_RELAY, OUTPUT);
  pinMode(MANUAL_BUTTON, INPUT_PULLUP);
  pinMode(WIFI_STATUS_LED, OUTPUT);

  // Turn off all relays (active LOW)
  digitalWrite(PUMP_RELAY, HIGH);
  digitalWrite(FAN1_RELAY, HIGH);
  digitalWrite(FAN2_RELAY, HIGH);
  digitalWrite(WIFI_STATUS_LED, LOW);

  // Connect WiFi
  WiFi.begin(ssid, password);
  Serial.print("Connecting to WiFi");
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print(PROJECT_NAME);
  lcd.print(" ");
  lcd.print(VERSION);
  lcd.setCursor(0, 1);
  lcd.print("WiFi Connecting");

  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED && attempts < 20)
  {
    Serial.print(".");
    lcd.setCursor(attempts % 16, 1);
    lcd.print(".");
    delay(500);
    attempts++;
  }

  if (WiFi.status() == WL_CONNECTED)
  {
    Serial.println("\nWiFi Connected!");
    digitalWrite(WIFI_STATUS_LED, HIGH);
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print(PROJECT_NAME);
    lcd.print(" ");
    lcd.print(VERSION);
    lcd.setCursor(0, 1);
    lcd.print("WiFi OK");
    delay(1500);
  }
  else
  {
    Serial.println("\nWiFi Failed!");
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print(PROJECT_NAME);
    lcd.print(" ");
    lcd.print(VERSION);
    lcd.setCursor(0, 1);
    lcd.print("WiFi Failed");
    delay(1500);
  }

  lcd.clear();
  Serial.println("System Ready!");
  Serial.println("Pump control mode: Based on WATER LEVEL only");
  Serial.print("Pump ON when water level > ");
  Serial.println(WATER_PUMP_ON);
  Serial.print("Pump OFF when water level < ");
  Serial.println(WATER_PUMP_OFF);
}

// ----------- READ SENSORS -----------
void readSensors()
{
  soilMoisture = analogRead(SOIL_PIN);
  lightLevel = analogRead(LDR_PIN);
  rainLevel = analogRead(RAIN_PIN);
  waterLevel = analogRead(WATER_LEVEL_PIN);

  float newTemp = dht.readTemperature();
  float newHum = dht.readHumidity();

  if (!isnan(newTemp))
    temperature = newTemp;
  if (!isnan(newHum))
    humidity = newHum;

  // Update rain status after reading rain sensor (for display only)
  updateRainStatus();
}

// ----------- CONTROL ACTUATORS -----------
void controlActuators()
{
  // === PUMP CONTROL BASED ON WATER LEVEL ONLY ===
  if (manualMode)
  {
    // Manual mode - direct control
    pumpStatus = manualPumpRequest;
  }
  else
  {
    // Auto mode - pump runs based on water level only
    // Turn pump ON when water level is high (above threshold)
    if (waterLevel > WATER_PUMP_ON && !pumpStatus)
    {
      pumpStatus = true;
      pumpStartTime = millis();
      Serial.print("💧 Pump ON - Water level HIGH (");
      Serial.print(waterLevel);
      Serial.print(" > ");
      Serial.print(WATER_PUMP_ON);
      Serial.println(")");
    }
    // Turn pump OFF when water level is low (below threshold)
    else if (waterLevel < WATER_PUMP_OFF && pumpStatus)
    {
      pumpStatus = false;
      Serial.print("💧 Pump OFF - Water level LOW (");
      Serial.print(waterLevel);
      Serial.print(" < ");
      Serial.print(WATER_PUMP_OFF);
      Serial.println(")");
    }

    // Emergency safety cutoff - critical water level
    if (waterLevel < WATER_CRITICAL)
    {
      if (pumpStatus)
      {
        pumpStatus = false;
        Serial.println("🚨 EMERGENCY: Pump OFF - Water CRITICAL!");
      }
    }

    // Pump runtime protection (max 30 minutes)
    if (pumpStatus && (millis() - pumpStartTime > 1800000))
    {
      pumpStatus = false;
      Serial.println("⚠️ Pump timeout - Auto OFF after 30min");
    }
  }

  // Apply pump state
  digitalWrite(PUMP_RELAY, pumpStatus ? LOW : HIGH);

  // === FAN 1 CONTROL (22°C with hysteresis) ===
  bool shouldFan1 = fan1Status;

  if (temperature > TEMP_FAN1_ON)
  {
    shouldFan1 = true;
  }
  else if (temperature < TEMP_FAN1_OFF)
  {
    shouldFan1 = false;
  }

  if (shouldFan1 != fan1Status)
  {
    fan1Status = shouldFan1;
    digitalWrite(FAN1_RELAY, fan1Status ? LOW : HIGH);
    Serial.print("🌀 Fan1: ");
    Serial.println(fan1Status ? "ON" : "OFF");
  }

  // === FAN 2 CONTROL (24°C with hysteresis) ===
  bool shouldFan2 = fan2Status;

  if (temperature > TEMP_FAN2_ON)
  {
    shouldFan2 = true;
  }
  else if (temperature < TEMP_FAN2_OFF)
  {
    shouldFan2 = false;
  }

  if (shouldFan2 != fan2Status)
  {
    fan2Status = shouldFan2;
    digitalWrite(FAN2_RELAY, fan2Status ? LOW : HIGH);
    Serial.print("🌀🌀 Fan2: ");
    Serial.println(fan2Status ? "ON" : "OFF");
  }

  // Critical temperature - both fans ON
  if (temperature > TEMP_CRITICAL)
  {
    if (!fan1Status)
    {
      fan1Status = true;
      digitalWrite(FAN1_RELAY, LOW);
    }
    if (!fan2Status)
    {
      fan2Status = true;
      digitalWrite(FAN2_RELAY, LOW);
    }
    Serial.println("🌡️ CRITICAL TEMP - Both fans ON");
  }
}

// ----------- CHECK BUTTON -----------
void checkButton()
{
  static unsigned long pressTime = 0;
  static bool buttonPressed = false;

  if (digitalRead(MANUAL_BUTTON) == LOW && !buttonPressed)
  {
    buttonPressed = true;
    pressTime = millis();
  }

  if (digitalRead(MANUAL_BUTTON) == HIGH && buttonPressed)
  {
    buttonPressed = false;
    if (millis() - pressTime < 2000)
    {
      // Short press - toggle manual mode
      manualMode = !manualMode;
      lcd.clear();
      lcd.setCursor(0, 0);
      lcd.print(PROJECT_NAME);
      lcd.print(" ");
      lcd.print(VERSION);
      lcd.setCursor(0, 1);
      lcd.print("Mode: ");
      lcd.print(manualMode ? "MANUAL" : "AUTO");
      delay(1500);
      lcd.clear();
    }
  }

  // Long press in manual mode
  if (manualMode && buttonPressed && (millis() - pressTime > 2000))
  {
    manualPumpRequest = !manualPumpRequest;
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print(PROJECT_NAME);
    lcd.print(" ");
    lcd.print(VERSION);
    lcd.setCursor(0, 1);
    lcd.print("Manual Pump ");
    lcd.print(manualPumpRequest ? "ON" : "OFF");
    delay(1000);
    lcd.clear();
    while (digitalRead(MANUAL_BUTTON) == LOW)
      ;
    buttonPressed = false;
  }
}

// ----------- UPDATE LCD -----------
void updateLCD()
{
  if (millis() - lastLCDUpdate < LCD_UPDATE_INTERVAL)
    return;
  lastLCDUpdate = millis();

  lcdScreen = (lcdScreen + 1) % TOTAL_SCREENS;
  lcd.clear();

  switch (lcdScreen)
  {
  case 0: // Screen 1: Project Info + Uptime
    lcd.setCursor(0, 0);
    lcd.print(PROJECT_NAME);
    lcd.print(" ");
    lcd.print(VERSION);

    lcd.setCursor(0, 1);
    lcd.print("Uptime: ");
    lcd.print(getTimeString());
    break;

  case 1: // Screen 2: Temperature & Time
    lcd.setCursor(0, 0);
    lcd.print("Temperature:");
    lcd.setCursor(0, 1);
    lcd.print(temperature, 1);
    lcd.print("C ");
    lcd.print(getTimeString());
    break;

  case 2: // Screen 3: Humidity
    lcd.setCursor(0, 0);
    lcd.print("Humidity:");
    lcd.setCursor(0, 1);
    lcd.print(humidity, 1);
    lcd.print("%");
    break;

  case 3: // Screen 4: Water Level (Primary)
    lcd.setCursor(0, 0);
    lcd.print("Water Level:");
    lcd.setCursor(0, 1);
    lcd.print(waterLevel);
    lcd.print(" (");
    if (waterLevel > WATER_PUMP_ON)
      lcd.print("HIGH");
    else if (waterLevel < WATER_PUMP_OFF)
      lcd.print("LOW");
    else
      lcd.print("MID");
    lcd.print(")");
    break;

  case 4: // Screen 5: Soil, Rain & System Status
    lcd.setCursor(0, 0);
    lcd.print("Soil:");
    lcd.print(soilMoisture);
    lcd.print(" Rain:");
    if (rainLevel < 500)
      lcd.print("D");
    else if (rainLevel < 1500)
      lcd.print("L");
    else
      lcd.print("H");

    lcd.setCursor(0, 1);
    lcd.print("P:");
    lcd.print(pumpStatus ? "ON " : "OFF");
    lcd.print("F1:");
    lcd.print(fan1Status ? "ON " : "OFF");
    lcd.print("F2:");
    lcd.print(fan2Status ? "ON" : "OFF");
    lcd.print(" M:");
    lcd.print(manualMode ? "M" : "A");
    break;
  }
}

