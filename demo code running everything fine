#define UPLOAD_INTERVAL 30000 // 30 seconds (ThingSpeak minimum is 15s)
#define SENSOR_READ_INTERVAL 2000
#define LCD_UPDATE_INTERVAL 2000

// ----------- OBJECTS -----------
DHT dht(DHTPIN, DHTTYPE);
